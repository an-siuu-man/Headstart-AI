# Required for webapp server routes
AGENT_SERVICE_URL=http://localhost:8000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-sb_secret-key
SUPABASE_ASSIGNMENT_PDF_BUCKET=assignment-pdfs
SUPABASE_ASSIGNMENT_PDF_SIGNED_URL_TTL_SECONDS=600
SUPABASE_ASSIGNMENT_IMAGE_BUCKET=assignment-images

# Required for browser auth + cookie session endpoints
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-anon-key

# Required for Google Calendar OAuth integration (Issue #43 / Req 11)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar.events openid email
